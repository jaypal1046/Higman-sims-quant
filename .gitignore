```gitignore
# Compiled Python files
*.pyc
__pycache__/

# LaTeX build artifacts
*.aux
*.log
*.toc
*.lof
*.lot
*.out
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.synctex.gz
*.pdf

# Dependencies
.venv/
venv/
env/
node_modules/

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs and temporary files
*.log
*.tmp

# Environment variables
.env
.env.local
*.env.*

# Coverage reports
coverage/
htmlcov/
.coverage

# Distribution files
dist/
build/
target/

# MyPy cache
.mypy_cache/
# Pytest cache
.pytest_cache/

# OS specific
.DS_Store
Thumbs.db
```